---
import Kaaba from './Kaaba.astro';
import type { Copy } from '../i18n/copy';

interface Props {
  t: Copy;
}
const { t } = Astro.props;
const rl = t.redLines;
const dir = t.dir;
---

<section class="rl-sec" style="padding:130px 60px;background:#1B5E4B;color:#F8F6F0;position:relative;overflow:hidden;border-top:1px solid #D4A843">
  <div style="position:absolute;inset:0;background:radial-gradient(circle at 20% 30%,rgba(212,168,67,0.08) 0%,transparent 40%),radial-gradient(circle at 80% 70%,rgba(212,168,67,0.06) 0%,transparent 40%);pointer-events:none"></div>

  <div class="rl-grid" style="position:relative;max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1.35fr;gap:80px;align-items:center">

    <!-- LEFT: intro -->
    <div>
      <div style="display:inline-flex;align-items:center;gap:10px;font-family:var(--sans);font-size:11px;letter-spacing:0.25em;color:#D4A843;text-transform:uppercase;margin-bottom:24px">
        <span style="width:24px;height:1px;background:#D4A843;display:inline-block"></span>
        {rl.eyebrow}
      </div>
      <h2 class="rl-h2" style="font-size:64px;line-height:0.98;font-weight:400;letter-spacing:-0.035em;margin:0;text-wrap:balance">
        {rl.h2Parts[0]}<br />{rl.h2Parts[1]}<em style="color:#E8C878;font-style:italic">{rl.h2Parts[2]}</em>{rl.h2Parts[3]}
      </h2>
      <p style="font-family:var(--sans);font-size:16px;line-height:1.7;color:rgba(245,242,232,0.6);margin-top:30px;font-weight:300;max-width:440px;text-wrap:pretty">
        {rl.lede}
      </p>
      <div style="display:flex;align-items:center;gap:14px;margin-top:44px;font-family:var(--sans);font-size:12px;color:rgba(245,242,232,0.45);letter-spacing:0.05em">
        <Kaaba size={18} />
        <span>{rl.signatureCaption}</span>
      </div>
      <div style="font-family:var(--sans);font-size:12px;color:#E8C878;font-style:italic;margin-top:6px;letter-spacing:0.02em">
        {rl.signatureLine}
      </div>
    </div>

    <!-- RIGHT: dynamic stage -->
    <div
      id="rl-stage"
      class="rl-stage"
      style="position:relative;min-height:520px;border-radius:8px;border:1px solid rgba(212,168,67,0.33);background:linear-gradient(160deg,#163300 0%,#143E32 100%);padding:56px 56px 80px;overflow:hidden;box-shadow:0 30px 60px -20px rgba(0,0,0,0.4),0 0 0 1px rgba(212,168,67,0.08),inset 0 1px 0 rgba(245,245,245,0.04)"
    >
      <!-- Ghost numeral -->
      <div id="rl-ghost" class="rl-ghost" aria-hidden="true" style={`position:absolute;top:-30px;${dir === 'rtl' ? 'left' : 'right'}:-20px;font-family:var(--serif);font-size:380px;font-weight:300;font-style:italic;color:rgba(212,168,67,0.05);line-height:0.85;letter-spacing:-0.05em;pointer-events:none`}>01</div>

      <!-- Items -->
      <div style="position:relative;min-height:360px">
        {rl.items.map((item, i) => (
          <div
            class="rl-item"
            data-idx={i}
            style={`position:${i === 0 ? 'relative' : 'absolute'};inset:${i === 0 ? 'auto' : '0'};opacity:${i === 0 ? 1 : 0};transform:${i === 0 ? 'translateY(0)' : 'translateY(16px)'};transition:opacity 700ms cubic-bezier(0.22,1,0.36,1),transform 700ms cubic-bezier(0.22,1,0.36,1);pointer-events:${i === 0 ? 'auto' : 'none'}`}
          >
            <div style="font-family:var(--sans);font-size:11px;letter-spacing:0.3em;color:#D4A843;text-transform:uppercase;font-weight:600;margin-bottom:28px;display:flex;align-items:center;gap:12px">
              <span>№ {String(i + 1).padStart(2, '0')}</span>
              <span style="width:32px;height:1px;background:#D4A843;opacity:0.5;display:inline-block"></span>
              <span style="color:rgba(245,242,232,0.4);letter-spacing:0.2em;font-weight:400">{item.tag}</span>
            </div>
            <h3 class="rl-h3" style="font-family:var(--serif);font-size:68px;line-height:1.05;font-weight:400;letter-spacing:-0.035em;margin:0;text-wrap:balance">
              <span style="color:#E8C878;font-style:italic;font-weight:300">{item.verb}</span>{' '}
              <strong style="font-weight:500">{item.bold}</strong>
              {item.rest && <><br /><span class="rl-rest" style="color:rgba(245,242,232,0.78);font-weight:300;font-size:42px;letter-spacing:-0.025em">{item.rest}</span></>}
            </h3>
            <p style="font-family:var(--sans);font-size:15px;line-height:1.65;color:rgba(245,242,232,0.55);margin-top:32px;font-weight:300;max-width:540px;font-style:italic;border-inline-start:2px solid #D4A843;padding-inline-start:18px">
              {item.why}
            </p>
          </div>
        ))}
      </div>

      <!-- Progress bars -->
      <div style="position:absolute;bottom:24px;left:56px;right:56px;display:flex;align-items:center;gap:16px;direction:ltr">
        {rl.items.map((_, i) => (
          <button
            class="rl-bar"
            data-bar={i}
            aria-label={`Show promise ${i + 1}`}
            style="flex:1;height:2px;padding:0;border:none;cursor:pointer;background:rgba(245,242,232,0.12);position:relative;overflow:hidden"
          >
            <span class="rl-fill" style={`position:absolute;inset:0;background:#D4A843;transform-origin:left;transform:scaleX(${i === 0 ? 1 : 0});transition:${i === 0 ? 'transform 5000ms linear' : 'transform 300ms'}`}></span>
          </button>
        ))}
        <div id="rl-counter" style="font-family:var(--sans);font-size:11px;color:rgba(245,242,232,0.45);letter-spacing:0.15em;font-variant-numeric:tabular-nums;min-width:40px;text-align:right">
          01<span style="color:rgba(245,242,232,0.2)"> / {String(rl.items.length).padStart(2, '0')}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const DURATION = 5000;
  let idx = 0;
  let paused = false;
  let timer: ReturnType<typeof setTimeout> | null = null;

  const items = document.querySelectorAll<HTMLElement>('.rl-item');
  const bars = document.querySelectorAll<HTMLButtonElement>('.rl-bar');
  const fills = document.querySelectorAll<HTMLElement>('.rl-fill');
  const ghost = document.getElementById('rl-ghost');
  const counter = document.getElementById('rl-counter');
  const stage = document.getElementById('rl-stage');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function show(newIdx: number) {
    // hide current
    const cur = items[idx];
    if (cur) {
      cur.style.position = 'absolute';
      cur.style.inset = '0';
      cur.style.opacity = '0';
      cur.style.transform = 'translateY(16px)';
      cur.style.pointerEvents = 'none';
    }
    // show new
    idx = newIdx;
    const next = items[idx];
    if (next) {
      next.style.position = 'relative';
      next.style.inset = 'auto';
      next.style.opacity = '1';
      next.style.transform = 'translateY(0)';
      next.style.pointerEvents = 'auto';
    }
    // update ghost
    if (ghost) ghost.textContent = String(idx + 1).padStart(2, '0');
    // update counter
    if (counter) counter.innerHTML = `${String(idx + 1).padStart(2, '0')}<span style="color:rgba(245,242,232,0.2)"> / ${String(items.length).padStart(2, '0')}</span>`;
    // update bars
    fills.forEach((fill, i) => {
      if (i < idx) {
        fill.style.transform = 'scaleX(1)';
        fill.style.transition = 'transform 300ms';
      } else if (i === idx) {
        fill.style.transform = 'scaleX(0)';
        fill.style.transition = 'none';
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            fill.style.transform = 'scaleX(1)';
            fill.style.transition = `transform ${DURATION}ms linear`;
          });
        });
      } else {
        fill.style.transform = 'scaleX(0)';
        fill.style.transition = 'transform 300ms';
      }
    });
  }

  function advance() {
    show((idx + 1) % items.length);
    if (!paused) scheduleNext();
  }

  function scheduleNext() {
    if (timer) clearTimeout(timer);
    timer = setTimeout(advance, DURATION);
  }

  bars.forEach((btn, i) => {
    btn.addEventListener('click', () => {
      show(i);
      if (!paused) scheduleNext();
    });
  });

  if (stage) {
    stage.addEventListener('mouseenter', () => {
      paused = true;
      if (timer) { clearTimeout(timer); timer = null; }
      fills.forEach((f, i) => {
        if (i === idx) { f.style.transition = 'none'; }
      });
    });
    stage.addEventListener('mouseleave', () => {
      paused = false;
      scheduleNext();
      fills.forEach((f, i) => {
        if (i === idx) {
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              f.style.transform = 'scaleX(1)';
              f.style.transition = `transform ${DURATION}ms linear`;
            });
          });
        }
      });
    });
  }

  if (!reduced) scheduleNext();
</script>
