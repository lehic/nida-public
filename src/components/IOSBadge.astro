---
interface Props {
  fg?: string;
  subtle?: string;
  eyebrow?: string;
  name?: string;
}
const {
  fg = '#FFFFFF',
  subtle = 'rgba(255,255,255,0.7)',
  eyebrow = 'iOS',
  name = 'Coming soon',
} = Astro.props;
const borderColor = fg === '#FFFFFF' ? 'rgba(255,255,255,0.35)' : 'rgba(0,0,0,0.3)';
---
<div style={`display:inline-flex;align-items:center;gap:12px;background:transparent;color:${fg};padding:13px 22px;border-radius:12px;border:1px dashed ${borderColor};min-width:200px;font-family:var(--sans);opacity:0.9;pointer-events:none`} aria-label="iOS — coming soon">
  <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true">
    <path d="M17.05 12.04c-.03-2.9 2.37-4.3 2.48-4.37-1.36-1.98-3.47-2.25-4.21-2.28-1.79-.18-3.5 1.05-4.41 1.05-.92 0-2.32-1.03-3.82-1-1.96.03-3.78 1.14-4.79 2.89-2.05 3.55-.52 8.79 1.47 11.66.97 1.4 2.13 2.98 3.65 2.92 1.47-.06 2.02-.95 3.79-.95 1.77 0 2.27.95 3.82.92 1.58-.03 2.58-1.43 3.55-2.83 1.12-1.62 1.58-3.19 1.61-3.27-.03-.01-3.09-1.19-3.14-4.74zM14.4 3.59c.81-.98 1.36-2.34 1.21-3.7-1.17.05-2.58.78-3.42 1.76-.75.87-1.41 2.27-1.23 3.6 1.3.1 2.63-.67 3.44-1.66z"/>
  </svg>
  <div style="line-height:1.1">
    <div style={`font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:${subtle}`}>{eyebrow}</div>
    <div style="font-size:15px;font-weight:500;letter-spacing:-0.01em">{name}</div>
  </div>
</div>
