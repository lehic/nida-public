---
interface Props {
  size?: number;
  gold?: string;
  black?: string;
}
const { size = 24, gold = '#D4A843', black = '#0A0A0A' } = Astro.props;
const h = size * 0.86;
---
<svg width={size} height={h} viewBox="0 0 100 86" style="display:block;flex-shrink:0" aria-hidden="true">
  <rect x="10" y="16" width="80" height="64" rx="3" fill={black} />
  <rect x="10" y="42" width="80" height="10" fill={gold} />
  <rect x="4" y="8" width="92" height="10" rx="2" fill={black} />
</svg>
