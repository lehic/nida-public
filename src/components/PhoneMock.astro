---
interface Props {
  src: string;
  alt?: string;
  width?: number;
  tilt?: number;
  shadow?: string;
}
const {
  src,
  alt = '',
  width = 240,
  tilt = 0,
  shadow = '0 40px 80px -30px rgba(0,0,0,0.4)',
} = Astro.props;
const h = Math.round(width * 2.165);
const outerR = Math.round(width * 0.09);
const innerR = Math.round(width * 0.07);
---
<div style={`width:${width}px;height:${h}px;border-radius:${outerR}px;background:#0A0A0A;padding:6px;transform:rotate(${tilt}deg);box-shadow:${shadow};flex-shrink:0;overflow:hidden`}>
  <div style={`width:100%;height:${h - 12}px;border-radius:${innerR}px;overflow:hidden;background:#F5F2E8`}>
    <img src={src} alt={alt} width={width - 12} height={h - 12} style="width:100%;height:100%;object-fit:cover;object-position:top center;display:block" loading="lazy" decoding="async" />
  </div>
</div>
