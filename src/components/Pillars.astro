---
import type { Copy } from '../i18n/copy';
interface Props { t: Copy }
const { t } = Astro.props;
const p = t.pillars;
---
<section style="padding:90px 60px;background:var(--nida-cream-deep)">
  <div style="max-width:1200px;margin:0 auto">
  <div style="display:grid;grid-template-columns:1fr 2fr;gap:60px;margin-bottom:70px">
    <div>
      <div class="eyebrow">{p.eyebrow}</div>
      <h2 style="font-size:54px;line-height:1;font-weight:400;letter-spacing:-0.03em;margin-top:18px;text-wrap:balance">
        {p.h2Lines.map((l, i) => (
          <>{l}{i < p.h2Lines.length - 1 && <br />}</>
        ))}
      </h2>
    </div>
    <p style="font-family:var(--sans);font-size:18px;line-height:1.65;color:var(--nida-stone);max-width:560px;align-self:end;font-weight:300;text-wrap:pretty">
      {p.lede}
    </p>
  </div>
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(107,107,107,0.2)">
    {p.items.map((item) => (
      <div style="background:var(--nida-cream-deep);padding:44px 36px 50px">
        <div style="font-family:var(--sans);font-size:12px;color:var(--nida-gold);letter-spacing:0.2em">{item.n}</div>
        <h3 style="font-size:34px;font-weight:400;letter-spacing:-0.02em;margin-top:16px;margin-bottom:14px">{item.t}</h3>
        <p style="font-family:var(--sans);font-size:15px;line-height:1.65;color:var(--nida-stone);font-weight:300;text-wrap:pretty">{item.d}</p>
      </div>
    ))}
  </div>
  </div>
</section>
