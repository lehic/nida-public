---
interface Props {
  bg?: string;
  fg?: string;
  subtle?: string;
  eyebrow?: string;
  name?: string;
  href?: string;
}
const {
  bg = '#0A0A0A',
  fg = '#FFFFFF',
  subtle = 'rgba(255,255,255,0.7)',
  eyebrow = 'Get it on',
  name = 'Google Play',
  href = 'https://play.google.com/apps/testing/com.nidaapp.nida',
} = Astro.props;
---
<a href={href} target="_blank" rel="noopener" style={`display:inline-flex;align-items:center;gap:12px;background:${bg};color:${fg};padding:14px 22px;border-radius:12px;text-decoration:none;min-width:200px;font-family:var(--sans)`}>
  <svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor" aria-hidden="true">
    <path d="M3.5 2.3c-.3.3-.5.8-.5 1.4v16.6c0 .6.2 1.1.5 1.4l.1.1 9.3-9.3v-.2L3.5 2.3zM16.8 15l-3.1-3.1v-.2l3.1-3.1 3.7 2.1c1.1.6 1.1 1.6 0 2.2L16.8 15zM13.7 12.1L16.8 15 5.6 21.4c-.4.2-.7.2-1 0l9.1-9.3zM5.6 2.6c.3-.2.6-.2 1 0l11.2 6.4-3.1 3.1-9.1-9.5z" />
  </svg>
  <div style="line-height:1.1">
    <div style={`font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:${subtle}`}>{eyebrow}</div>
    <div style="font-size:17px;font-weight:600;letter-spacing:-0.01em">{name}</div>
  </div>
</a>
