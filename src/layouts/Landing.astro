---
import '../styles/fonts.css';
import '../styles/tokens.css';
import '../styles/responsive.css';
import type { Lang } from '../i18n/copy';

interface Props {
  lang: Lang;
  dir: 'ltr' | 'rtl';
  title: string;
  description: string;
  canonical: string;
}
const { lang, dir, title, description, canonical } = Astro.props;

const baseUrl = `${Astro.site}${import.meta.env.BASE_URL}`;
const ogImage = `${baseUrl}brand-kit/app-icon/app-icon-1024.png`;

const altLinks = [
  { lang: 'en', href: baseUrl },
  { lang: 'fr', href: `${baseUrl}fr` },
  { lang: 'ar', href: `${baseUrl}ar` },
];
---
<!DOCTYPE html>
<html lang={lang} dir={dir}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {altLinks.map((a) => <link rel="alternate" hreflang={a.lang} href={a.href} />)}
  <link rel="alternate" hreflang="x-default" href={baseUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="nida" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1024" />
  <meta property="og:image:height" content="1024" />
  <meta property="og:image:alt" content="nida — Islamic prayer times app" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- JSON-LD: SoftwareApplication -->
  <script type="application/ld+json" set:text={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "nida",
    "operatingSystem": ["Android", "iOS"],
    "applicationCategory": "LifestyleApplication",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "description": description,
    "downloadUrl": "https://play.google.com/store/apps/details?id=com.nidaapp.nida",
    "keywords": "islamic prayer times, prayer times app, athan app, qibla, Muslim, offline, salat, namaz",
  })} />

  <!-- JSON-LD: Organization -->
  <script type="application/ld+json" set:text={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "nida",
    "url": "https://nida.day",
    "logo": `${Astro.site}brand-kit/app-icon/app-icon-1024.png`,
    "description": "nida is a free Islamic prayer times app — no ads, no data collection, works offline.",
  })} />

  <slot name="head" />

  <meta name="theme-color" content="#143E32" />
</head>
<body>
  <slot />
</body>
</html>
