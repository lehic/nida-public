---
import Landing from '../../layouts/Landing.astro';
import Hero from '../../components/Hero.astro';
import RedLines from '../../components/RedLines.astro';
import Pillars from '../../components/Pillars.astro';
import InsideApp from '../../components/InsideApp.astro';
import Method from '../../components/Method.astro';
import FAQ from '../../components/FAQ.astro';
import Verse from '../../components/Verse.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';
import { COPY } from '../../i18n/copy';

const lang = 'fr';
const t = COPY[lang];
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: t.faq.items.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---
<Landing
  lang={lang}
  dir={t.dir}
  title="nida — Horaires de prière islamique, hors-ligne. Sans pub."
  description="Application horaires de prière islamique gratuite — Athan précis, Qibla et suivi des prières. Sans pub, sans données, fonctionne hors-ligne."
  canonical="https://nida.day/fr"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <Hero t={t} lang={lang} />
  <RedLines t={t} />
  <Pillars t={t} />
  <InsideApp t={t} lang={lang} />
  <Method t={t} />
  <FAQ t={t} />
  <Verse t={t} />
  <CTA t={t} />
  <Footer t={t} lang={lang} />
</Landing>
