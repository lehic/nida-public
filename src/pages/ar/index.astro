---
import Landing from '../../layouts/Landing.astro';
import Hero from '../../components/Hero.astro';
import RedLines from '../../components/RedLines.astro';
import Pillars from '../../components/Pillars.astro';
import InsideApp from '../../components/InsideApp.astro';
import Method from '../../components/Method.astro';
import FAQ from '../../components/FAQ.astro';
import Verse from '../../components/Verse.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';
import { COPY } from '../../i18n/copy';

const lang = 'ar';
const t = COPY[lang];
---
<Landing
  lang={lang}
  dir={t.dir}
  title="نِدَاء — مواقيت الصلاة الإسلامية، بدون إنترنت. بلا إعلانات."
  description="لا إعلانات. لا ضجيج. لا أحكام. رفيق صلاة يعمل دون إنترنت مع أذان دقيق وقبلة ومتابعة الصلوات."
  canonical="https://lehic.github.io/nida-public/ar"
>
  <Hero t={t} lang={lang} />
  <RedLines t={t} />
  <Pillars t={t} />
  <InsideApp t={t} lang={lang} />
  <Method t={t} />
  <FAQ t={t} />
  <Verse t={t} />
  <CTA t={t} />
  <Footer t={t} lang={lang} />
</Landing>
