---
import Landing from '../layouts/Landing.astro';
import Hero from '../components/Hero.astro';
import RedLines from '../components/RedLines.astro';
import Pillars from '../components/Pillars.astro';
import InsideApp from '../components/InsideApp.astro';
import Method from '../components/Method.astro';
import FAQ from '../components/FAQ.astro';
import Verse from '../components/Verse.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import { COPY } from '../i18n/copy';

const lang = 'en';
const t = COPY[lang];
---
<Landing
  lang={lang}
  dir={t.dir}
  title="nida — Islamic prayer times, offline. No ads."
  description="No ads. No noise. No judgment. Offline-first Islamic prayer companion with accurate Athan, Qibla, and prayer tracking."
  canonical="https://lehic.github.io/nida-public/"
>
  <Hero t={t} lang={lang} />
  <RedLines t={t} />
  <Pillars t={t} />
  <InsideApp t={t} lang={lang} />
  <Method t={t} />
  <FAQ t={t} />
  <Verse t={t} />
  <CTA t={t} />
  <Footer t={t} lang={lang} />
</Landing>
